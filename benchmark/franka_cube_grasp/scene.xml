<mujoco model="panda cube grasp">
  <include file="panda.xml"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.25 0.25 0.25" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="135" elevation="-25"/>
    <!-- <scale contactwidth="0.075" contactheight="0.025" forcewidth="0.05"/> -->
  </visual>

  <asset>
    <texture
      type="skybox"
      builtin="gradient"
      rgb1="0.30 0.45 0.60"
      rgb2="0.02 0.03 0.04"
      width="512"
      height="3072"
    />
    <texture
      type="2d"
      name="groundplane"
      builtin="checker"
      mark="edge"
      rgb1="0.20 0.28 0.34"
      rgb2="0.12 0.16 0.20"
      markrgb="0.85 0.85 0.85"
      width="300"
      height="300"
    />
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="pedestal_mat" rgba="0.28 0.30 0.34 1"/>
    <material name="cube_mat" rgba="0.88 0.42 0.22 1"/>
  </asset>

  <default>
    <default class="pedestal">
      <geom
        type="box"
        material="pedestal_mat"
        contype="1"
        conaffinity="1"
        friction="1.0 0.08 0.01"
        condim="3"
      />
    </default>
    <default class="cube">
      <geom
        type="box"
        size="0.025 0.025 0.025"
        mass="0.15"
        material="cube_mat"
        contype="1"
        conaffinity="1"
        friction="1. 0.06 0.01"
        condim="6"
      />
    </default>
  </default>

  <worldbody>
    <light pos="0.4 -0.2 1.6" dir="0 0 -1" directional="true"/>
    <camera name="overview" pos="1.15 -0.70 0.65" xyaxes="0.51 0.86 0.00 -0.30 0.18 0.94"/>

    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="pedestal" pos="0.58 0 0.06">
      <geom class="pedestal" size="0.05 0.07 0.06"/>
    </body>

    <body name="cube" pos="0.58 0 0.145">
      <freejoint name="cube_freejoint"/>
      <geom name="cube_geom" class="cube"/>
    </body>
  </worldbody>

  <keyframe>
    <key
      name="home"
      qpos="0 0.3 0 -2.1 0 2.4 0.78 0.04 0.04 0.58 0 0.145 1 0 0 0"
      ctrl="0 0.3 0 -2.1 0 2.4 0.78 0.04"
    />
  </keyframe>
</mujoco>
